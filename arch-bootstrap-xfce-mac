#!/usr/bin/env bash
set -euo pipefail

# Linux Gamer Life Arch Bootstrap (TTY friendly)
# Goal: Start from Arch minimal (TTY), run once, reboot into XFCE with LightDM.
# Notes:
# - No Flatpak (disk space).
# - Not enabling multilib (no gaming).
# - Adds a few KDE apps (Dolphin, Discover, KWrite, Spectacle) on top of XFCE.

# -----------------------------
# Colours (LGL style)
# -----------------------------
GREEN='\033[38;2;0;255;0m'
ORANGE='\033[38;2;255;153;0m'
RED='\033[38;2;255;68;68m'
WHITE='\033[38;2;249;249;249m'
RESET='\033[0m'
BOLD='\033[1m'

section() { printf "\n${BOLD}${GREEN}==> %s${RESET}\n" "$1"; }
info() { printf "${WHITE}%s${RESET}\n" "$1"; }
warn() { printf "${BOLD}${RED}Warning:${RESET} ${WHITE}%s${RESET}\n" "$1"; }
cmdhint() { printf "${ORANGE}%s${RESET}\n" "$1"; }

require_root() {
  if [[ ${EUID} -ne 0 ]]; then
    warn "Run with sudo:"
    cmdhint "sudo bash $0"
    exit 1
  fi
}

get_target_user() {
  if [[ -n "${SUDO_USER:-}" && "${SUDO_USER}" != "root" ]]; then
    printf "%s" "${SUDO_USER}"
  else
    printf "%s" "$(logname 2>/dev/null || echo root)"
  fi
}

printf "${BOLD}${GREEN}Linux Gamer Life Arch XFCE Bootstrap${RESET}\n"
require_root

TARGET_USER="$(get_target_user)"
info "Target user: ${TARGET_USER}"

# -----------------------------
# 1) Update system
# -----------------------------
section "System update"

pacman -Syu --noconfirm

# -----------------------------
# 2) Core tools + baseline desktop plumbing
# -----------------------------
section "Core tools and desktop plumbing"

pacman -S --noconfirm \
  curl wget git base-devel \
  fastfetch btop htop \
  python python-pip \
  dbus \
  networkmanager \
  xorg-server \
  pipewire pipewire-alsa pipewire-pulse wireplumber \
  polkit-gnome \
  udisks2 upower \
  gvfs gvfs-smb \
  xdg-user-dirs xdg-utils

# Enable core services needed on a laptop/desktop
section "Enable services"

systemctl enable NetworkManager
systemctl enable dbus

# Create common user folders (Desktop, Downloads, etc.) on first boot
# This runs as root here, but it creates folders for the current environment user.
# If it fails in TTY, it is safe to ignore.
section "XDG user dirs (best effort)"
xdg-user-dirs-update || true

# -----------------------------
# 3) XFCE (core only) + LightDM
# -----------------------------
section "Install XFCE core + LightDM"

pacman -S --noconfirm \
  xfce4 \
  lightdm \
  lightdm-gtk-greeter

# Enable display manager so you get a graphical login
section "Enable display manager"

systemctl enable lightdm

# -----------------------------
# 4) Important desktop apps
# -----------------------------
section "Install important apps"

pacman -S --noconfirm \
  firefox \
  libreoffice-fresh

# -----------------------------
# 5) KDE apps you want on XFCE
# -----------------------------
section "Install KDE apps on XFCE"

pacman -S --noconfirm \
  dolphin \
  discover \
  kwrite \
  spectacle \
  kio

# -----------------------------
# 6) Full FFmpeg codec support (optional, but you had it in your original)
# -----------------------------
section "Media codecs (FFmpeg full stack)"

pacman -S --noconfirm \
  ffmpeg \
  x264 x265 libvpx dav1d svt-av1 libaom \
  opus lame libvorbis libwebp libass || true

# -----------------------------
# 7) Boot target
# -----------------------------
section "Boot configuration"

systemctl set-default graphical.target

# -----------------------------
# Finish
# -----------------------------
section "Complete"

info "Bootstrap finished"
info "Reboot to start XFCE:"
cmdhint "reboot"
